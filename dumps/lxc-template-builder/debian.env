# Debian-specific settings for cloudbuild-debian.yaml.
# Shared Cloud Build settings (project/region/bucket) live in build.env.
#
# Usage: DISTRO=debian ./submit-build.sh

# Debian release codename to debootstrap fresh from deb.debian.org
DEBIAN_RELEASE=trixie

# Space-separated apt package list to install on top of the base template
PACKAGES=htop
