# Copy this file to build-debian.env and fill in real values:
#   cp build-debian.env.example build-debian.env
# build-debian.env is gitignored so your project/bucket details never get committed.

# GCP project that will run the Cloud Build job
PROJECT_ID=your-gcp-project-id

# GCS bucket where the finished template gets uploaded (under /custom).
# No trailing slash.
BUCKET=gs://your-bucket-name

# Debian release codename to debootstrap fresh from deb.debian.org
DEBIAN_RELEASE=trixie

# Space-separated apt package list to install on top of the base template
PACKAGES=htop
