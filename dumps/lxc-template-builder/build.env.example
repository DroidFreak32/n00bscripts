# Copy this file to build.env and fill in real values:
#   cp build.env.example build.env
# build.env is gitignored so your project/bucket details never get committed.

# GCP project that will run the Cloud Build job
PROJECT_ID=your-gcp-project-id

# GCS bucket where the finished template gets uploaded (under /custom).
# No trailing slash.
BUCKET=gs://your-bucket-name

# Filename of the Arch bootstrap tarball on the official mirror
# (geo.mirror.pkgbuild.com/iso/latest/) - "latest" always points to the
# current release, no date/version needed.
BASE_IMAGE=archlinux-bootstrap-x86_64.tar.zst

# Space-separated pacman package list to install on top of the base template
PACKAGES=htop
